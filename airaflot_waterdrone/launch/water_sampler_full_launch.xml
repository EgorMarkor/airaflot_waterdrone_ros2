<launch>
    <include file="$(find-pkg-share mavros)/launch/apm.launch">
        <arg name="fcu_url" value="/dev/ttyACM0:57600" />
    </include>
    <include file="$(find-pkg-share airaflot_waterdrone)/launch/webserver_launch.xml"/>
    <node pkg="airaflot_waterdrone" exec="water_sampler_scenario" name="water_sampler_scenario" respawn="true" ros_args="--log-file-name water_sampler_scenario"/>
    <node pkg="airaflot_waterdrone" exec="water_sampler_rele" name="water_sampler_rele" respawn="true" ros_args="--log-file-name water_sampler_rele"/>
    <node pkg="airaflot_waterdrone" exec="water_sampler_motor" name="water_sampler_motor" respawn="true" ros_args="--log-file-name water_sampler_motor"/>
    <node pkg="airaflot_waterdrone" exec="water_sampler" name="water_sampler" respawn="true" ros_args="--log-file-name water_sampler"/>
    <node pkg="airaflot_waterdrone" exec="mode_controller_helper" name="mode_controller_helper" respawn="true" ros_args="--log-file-name mode_controller_helper"/>

</launch>